# ==============================================================
# Variables d'environnement — music221 API
# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS committer le fichier .env dans git
# ==============================================================

# --- Base de données PostgreSQL ---
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/music221?schema=public"

# URL directe (utilisée par Prisma pour les migrations)
# Peut être identique à DATABASE_URL si pas de pooler (ex: PgBouncer)
DIRECT_URL="postgresql://user:password@localhost:5432/music221?schema=public"

# --- Serveur ---
PORT=3000
NODE_ENV=development   # development | production | test
